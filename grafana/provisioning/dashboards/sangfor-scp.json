    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource",
        "label": "Datasource"
      },
      {
        "name": "az",
        "label": "Resource Pool",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "query": {
          "query": "label_values(sangfor_resource_pool_up, az_name)",
          "refId": "StandardVariableQuery"
        },
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "refresh": 2,
        "sort": 1,
        "hide": 0,
        "current": {}
      },
      {
        "name": "az_id",
        "label": "AZ ID (hidden)",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "query": {
          "query": "label_values(sangfor_resource_pool_up{az_name=~\"$az\"}, az_id)",
          "refId": "StandardVariableQuery"
        },
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "refresh": 2,
        "sort": 1,
        "hide": 2,
        "current": {}
      }
    ]
  },
